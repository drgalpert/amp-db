<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.peptidosdb.ui.controller.FuentesTabController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="8">
        <ComboBox fx:id="comboFuente" promptText="Fuente (ej. DRAMP, UniProt)" prefWidth="200"/>
        <TextField fx:id="campoPrioridad" promptText="Prioridad (número)" prefWidth="140"/>
        <Button text="Agregar / actualizar" onAction="#onAgregar"/>
    </HBox>

    <TableView fx:id="tablaFuentes" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colFuente" text="Fuente" prefWidth="220"/>
            <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="90"/>
        </columns>
    </TableView>

    <Button text="Eliminar seleccionada" onAction="#onEliminar"/>
</VBox>
