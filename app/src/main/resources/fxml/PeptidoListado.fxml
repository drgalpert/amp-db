<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.peptidosdb.ui.controller.PeptidoListadoController"
            prefWidth="900" prefHeight="560">

    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="8" left="12"/>
            </padding>
            <HBox spacing="10">
                <Label fx:id="etiquetaUsuario" style="-fx-font-weight: bold;"/>
                <Button text="Cerrar sesión" onAction="#onCerrarSesion"/>
            </HBox>
            <HBox spacing="8">
                <TextField fx:id="campoBusqueda" promptText="Buscar por nombre o secuencia..." prefWidth="320"/>
                <Button text="Buscar" onAction="#onBuscar"/>
                <Button fx:id="botonNuevo" text="Nuevo péptido" onAction="#onNuevo"/>
                <Button fx:id="botonEditar" text="Editar" onAction="#onEditar"/>
                <Button fx:id="botonDarBaja" text="Dar de baja" onAction="#onDarDeBaja"/>
                <Button text="Exportar a Excel" onAction="#onExportarExcel" fx:id="botonExportar"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablaPeptidos">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colNombre" text="Nombre principal" prefWidth="220"/>
                <TableColumn fx:id="colNombresAlt" text="Nombres alternativos" prefWidth="200"/>
                <TableColumn fx:id="colSecuencia" text="Secuencia" prefWidth="220"/>
                <TableColumn fx:id="colLongitud" text="Longitud" prefWidth="70"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="150"/>
                <TableColumn fx:id="colOrganismo" text="Organismo fuente" prefWidth="180"/>
                <TableColumn fx:id="colOrganismos" text="Organismos blanco" prefWidth="220"/>
                <TableColumn fx:id="colActividades" text="Actividades" prefWidth="220"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <Label fx:id="etiquetaEstado" style="-fx-text-fill: #a33;">
            <BorderPane.margin>
                <Insets top="6" right="12" bottom="10" left="12"/>
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>
