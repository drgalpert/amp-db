<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.peptidosdb.ui.controller.PublicacionesTabController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="8">
        <TextField fx:id="campoPmid" promptText="PMID (ej. 25123456)" prefWidth="180"/>
        <Button text="Agregar" onAction="#onAgregar"/>
    </HBox>

    <TableView fx:id="tablaPublicaciones" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colPmid" text="PMID" prefWidth="100"/>
            <TableColumn fx:id="colTitulo" text="Título" prefWidth="260"/>
            <TableColumn fx:id="colAnyo" text="Año" prefWidth="60"/>
        </columns>
    </TableView>

    <Button text="Quitar seleccionada" onAction="#onEliminar"/>
</VBox>
