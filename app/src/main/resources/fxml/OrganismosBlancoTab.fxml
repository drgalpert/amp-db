<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.peptidosdb.ui.controller.OrganismosBlancoTabController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="8">
        <ComboBox fx:id="comboOrganismo" promptText="Organismo blanco" prefWidth="220"/>
        <TextField fx:id="campoMicValor" promptText="MIC (valor)" prefWidth="100"/>
        <TextField fx:id="campoMicUnidad" promptText="Unidad (ej. µg/mL)" prefWidth="120"/>
        <Button text="Agregar / actualizar" onAction="#onAgregar"/>
    </HBox>

    <TableView fx:id="tablaOrganismos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrganismo" text="Organismo" prefWidth="220"/>
            <TableColumn fx:id="colMicValor" text="MIC valor" prefWidth="100"/>
            <TableColumn fx:id="colMicUnidad" text="MIC unidad" prefWidth="110"/>
        </columns>
    </TableView>

    <Button text="Eliminar seleccionado" onAction="#onEliminar"/>
</VBox>
